{
  "name": "jobber-auth-scripts",
  "private": true,
  "scripts": {
    "build": "npx nx build jobber-auth",
    "start:dev": "concurrently -k -n serve,watch -c blue,magenta \"npx nx serve jobber-auth\" \"npx nx watch --projects=jobber-auth --includeDependentProjects -- npx nx serve jobber-auth\"",
    "test": "npx jest --config jest.config.cts",
    "prisma:generate": "npx nx run jobber-auth:prisma-generate",
    "prisma:migrate": "npx prisma migrate dev",
    "prisma:studio": "npx prisma studio",
    "prisma:format": "npx nx run jobber-auth:prisma-format",
    "graphql:playground": "open http://localhost:3000/graphiql || start http://localhost:3000/graphiql"
  }
}
